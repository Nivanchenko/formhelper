// Инициализирует весь механизм расширения включая работу с динамическими списками и таблицами
//
// Параметры:
//    _Форма - Форма - форма в которую предполагается добавлять новые элементы
//
Процедура Инициализация(_Форма) Экспорт

	Форма = _Форма;
	ДобавляемыеРеквизиты = Новый Массив;
	ТаблицаКоманд();
	ТаблицаЭлементов();
	ПутьРеквизита = "";
	
	ИнициализацияКомпонентов();
	
КонецПроцедуры

// Возвращает форму для которой инициализирован механизм динамического изменения форм
//
// Возвращаемое значение:
//     Форма - 
//
Функция Форма() Экспорт
	Возврат Форма;	
КонецФункции // Форма()

#КонецОбласти

#Область Реквизиты__Р

// Добавляет новый реквизит в массив добавляемых реквизитов
// 
// Параметры:
//    Имя - Строка        - имя реквизита
//    Тип - ОписаниеТипов - тип реквизита
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция ДобавитьРеквизит(Имя, Тип) Экспорт
 
	ПроверитьИмя(Имя, "ДобавитьРеквизит");
	Если Не ТипЗнч(Тип) = Тип("ОписаниеТипов") Тогда
		ВызватьИсключение СтрШаблон("ДобавитьРеквизит %1: тип параметра ""Тип"" должен быть ""ОписаниеТипов""", Имя);
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Тип) Тогда
		ВызватьИсключение СтрШаблон("ДобавитьРеквизит %1: параметр ""Тип"" должен быть заполнен", Имя);
	КонецЕсли;

	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(Имя, Тип, ПутьРеквизита));	
	
	Возврат ЭтотОбъект;

КонецФункции // ДобавитьРеквизит()

// Выполняет добавление описанных ранее реквизитов на форму
// 
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция СоздатьРеквизиты() Экспорт

	Если ДобавляемыеРеквизиты.Количество() > 0 Тогда
		Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);	
	КонецЕсли;
	
	ДобавляемыеРеквизиты = Новый Массив;
	
	Возврат ЭтотОбъект;

КонецФункции // СоздатьРеквизиты()

// Добавляет новый реквизит в массив добавляемых реквизитов с типом "Дата"
// 
// Параметры:
//    Имя       - Строка    - имя реквизита
//    ЧастьДаты - ЧастиДаты - определяет допустимые части даты
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция РеквизитДата(Имя, ЧастьДаты = Неопределено) Экспорт 
	
	ПроверитьИмя(Имя, "РеквизитДата");
	Если Не ТипЗнч(ЧастьДаты) = Тип("Неопределено") И Не ТипЗнч(ЧастьДаты) = Тип("ЧастиДаты") Тогда
		ВызватьИсключение СтрШаблон("РеквизитДата %1: тип параметра ""ЧастьДаты""
			|должен быть ""ЧастиДаты"" или ""Неопределено""", Имя);
	КонецЕсли;

	Если ЧастьДаты = Неопределено Тогда
		ЧастьДаты = ЧастиДаты.ДатаВремя;
	КонецЕсли;
	
	ТипРеквизита = Новый ОписаниеТипов("Дата",,,Новый КвалификаторыДаты(ЧастьДаты));
	
	ДобавитьРеквизит(Имя, ТипРеквизита); 
	
	Возврат ЭтотОбъект;
	
КонецФункции
	
// Добавляет новый реквизит в массив добавляемых реквизитов с типом "Булево"
// 
// Параметры:
//    Имя - Строка - имя реквизита
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция РеквизитБулево(Имя) Экспорт 
	
	ПроверитьИмя(Имя, "РеквизитБулево");

	ТипРеквизита = Новый ОписаниеТипов("Булево");
	
	ДобавитьРеквизит(Имя, ТипРеквизита); 
	
	Возврат ЭтотОбъект;
	
КонецФункции
	
// Добавляет новый реквизит в массив добавляемых реквизитов с типом "Число"
//
// Параметры:
//    Имя      - Строка - имя реквизита
//    Размер   - Число  - общее число разрядов числа
//    Точность - Число  - число разрядов дробной части числа
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция РеквизитЧисло(Имя, Размер = 15, Точность = 2) Экспорт 
	
	ПроверитьИмя(Имя, "РеквизитЧисло");
	Если Не ТипЗнч(Размер) = Тип("Число") Тогда
		ВызватьИсключение СтрШаблон("РеквизитЧисло %1: параметр ""Размер"" должен быть числового типа", Имя);
	КонецЕсли;
	Если Не ТипЗнч(Точность) = Тип("Число") Тогда
		ВызватьИсключение СтрШаблон("РеквизитЧисло %1: параметр ""Точность"" должен быть числового типа", Имя);
	КонецЕсли;
	
	ТипРеквизита = Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(Размер, Точность));
	
	ДобавитьРеквизит(Имя, ТипРеквизита); 
	
	Возврат ЭтотОбъект;
	
КонецФункции
	
// Добавляет новый реквизит в массив добавляемых реквизитов с типом "Строка"
//
// Параметры:
//    Имя   - Строка - имя реквизита
//    Длина - Число  - допустимая длина строки. Если параметр не указан, то строка по длине не ограничивается
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция РеквизитСтрока(Имя, Длина = Неопределено) Экспорт 
	
	ПроверитьИмя(Имя, "РеквизитСтрока");
	Если Не ТипЗнч(Длина) = Тип("Неопределено") И Не ТипЗнч(Длина) = Тип("Число") Тогда
		ВызватьИсключение СтрШаблон("РеквизитСтрока %1: параметр ""Точность""
			|должен быть числового типа или ""Неопределено""", Имя);
	КонецЕсли;

	Если Длина = Неопределено Тогда
		ТипРеквизита = Новый ОписаниеТипов("Строка");
	Иначе
		ТипРеквизита = Новый ОписаниеТипов("Строка",,Новый КвалификаторыСтроки(Длина));
	КонецЕсли;
	
	ДобавитьРеквизит(Имя, ТипРеквизита); 
	
	Возврат ЭтотОбъект;
	
КонецФункции

// Добавляет новый реквизит в массив добавляемых реквизитов с типом "СтандартныйПериод"
