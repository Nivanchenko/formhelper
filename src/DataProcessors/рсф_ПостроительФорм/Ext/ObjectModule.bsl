//
Функция Команда(Имя, Метод) Экспорт
	
	ТекущаяКоманда = ПараметрыСозданияКоманды();
	ТекущаяКоманда.Имя = Имя;
	ТекущаяКоманда.Действие = Метод;
	
	ТекущийПоток = ТекущаяКоманда;
	
	Команда = Команды.Добавить();
	Команда.Имя = Имя;
	Команда.Параметры = ТекущаяКоманда;
	
	Возврат ЭтотОбъект;

КонецФункции // Команда()

// Устанавливает признак того что команда изменяет сохраняемые данные
//
// Параметры:
//    ИзменяетСохраняемыеДанные - Булево - признак
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция ИзменяетСохраняемыеДанные(ИзменяетСохраняемыеДанные) Экспорт
	
	Если Не ТипЗнч(ИзменяетСохраняемыеДанные) = Тип("Булево") Тогда
		ВызватьИсключение "ИзменяетСохраняемыеДанные: параметр ""ИзменяетСохраняемыеДанные"" должен иметь тип ""Булево""";
	КонецЕсли;
	Если Не ЭтоКоманда() Тогда
		ВызватьИсключение "ИзменяетСохраняемыеДанные: установка свойства ""ИзменяетСохраняемыеДанные""
			|доступно только для команд";
	КонецЕсли;

	Свойство("ИзменяетСохраняемыеДанные", ИзменяетСохраняемыеДанные);
	
	Возврат ЭтотОбъект;
	
КонецФункции

#КонецОбласти

#Область Элементы__Э

// Добавляет данные нового элемента формы
//
// Параметры:
//    Имя - Строка - имя элемента формы
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция ДобавитьЭлементФормы(Имя) Экспорт
	
	ПроверитьИмя(Имя, "ДобавитьЭлементФормы");

	ТекущийЭлемент = ПараметрыСозданияЭлементов();
	ТекущийЭлемент.Имя = Имя;
	
	ТекущийПоток = ТекущийЭлемент;
	
	Элемент = Элементы.Добавить();
	Элемент.Имя = Имя;
	Элемент.Параметры = ТекущийЭлемент;
	
	Возврат ЭтотОбъект;

КонецФункции // ДобавитьЭлементФормы()

