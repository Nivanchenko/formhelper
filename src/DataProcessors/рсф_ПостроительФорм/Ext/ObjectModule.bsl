// Устанавливает свойство элемента формы
//
// Параметры:
//    Имя      - Строка       - имя свойства элемента
//    Значение - Произвольный - значение свойства элемента
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция Свойство(Имя, Значение) Экспорт
	
	ПроверитьТекущийПоток();
	
	ТекущийПоток.Вставить(Имя, Значение);
	
	Возврат ЭтотОбъект;

КонецФункции // Свойство()

// Устанавливает тип элемента формы
//
// Параметры:
//    Тип - Тип - допустимые типы ПолеФормы, ГруппаФормы, КнопкаФормы, ТаблицаФормы, ДекорацияФормы
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция ТипЭлемента(Тип) Экспорт 

	ЭтоДопустимыйТип = Тип = Тип("ПолеФормы")
		Или Тип = Тип("ГруппаФормы")
		Или Тип = Тип("КнопкаФормы")
		Или Тип = Тип("ТаблицаФормы")
		Или Тип = Тип("ДекорацияФормы");
	Если Не ЭтоДопустимыйТип Тогда
		ВызватьИсключение "ТипЭлемента: передан недопустимый тип элемента";
	КонецЕсли;

	Свойство("Тип", Тип);
	
	Возврат ЭтотОбъект;

КонецФункции

// Устанавливает вид элемента формы
//
// Параметры:
//    Вид - ВидПоляФормы, ВидГруппыФормы, ВидДекорацииФормы - вид элемента
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция ВидЭлемента(Вид) Экспорт 

	Если ТекущийПоток = Неопределено Или ТекущийПоток.Тип = Неопределено Тогда
		ВызватьИсключение "ВидЭлемента: не задан тип элемента";
	КонецЕсли;
	Если Не ПроверитьВидЭлементаПоТипу(Вид) Тогда
		ВызватьИсключение СтрШаблон("ВидЭлемента: для типа %1 устанавливается некорректный вид элемента - %2",
			ТекущийПоток.Тип, Вид);
	КонецЕсли;

	Свойство("Вид", Вид);
	
	Возврат ЭтотОбъект;

КонецФункции

// Устанавливает место для последующего перемещения элемента (смена родителя) во время генерации
