// само поле ввода обрабатывает нажатие клавиши TAB 
//
// Параметры:
//    РасширенноеРедактирование - Булево, Неопределено - 
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция РасширенноеРедактирование(РасширенноеРедактирование) Экспорт 

	ИмяСвойства = "РасширенноеРедактирование";

	МассивИменТипа = Новый Массив;
	МассивИменТипа.Добавить("Булево");
	МассивИменТипа.Добавить("Неопределено");

	ПроверитьТипВходящегоПараметра(РасширенноеРедактирование, ИмяСвойства, МассивИменТипа);
	ПроверитьСвойствоДоступноТолькоДляПоляВвода(ИмяСвойства);

	Свойство(ИмяСвойства, РасширенноеРедактирование);
	
	Возврат ЭтотОбъект;

КонецФункции

