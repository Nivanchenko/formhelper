// Устанавливает форматную строку для текста или текстового представления значения типа булево (флажок, тумблер)
//
// Параметры:
//    ФорматРедактирования - Строка - 
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция ФорматРедактирования(ФорматРедактирования) Экспорт 

	ИмяСвойства = "ФорматРедактирования";
	ИмяТипа = "Строка";

	ПроверитьТипВходящегоПараметра(ФорматРедактирования, ИмяСвойства, ИмяТипа);
	ПроверитьСвойствоДоступноТолькоДляЭлемента(ИмяСвойства);
	Если Не ТекущийПоток.Тип = Тип("ПолеФормы")
		Или Не (ТекущийПоток.Вид = ВидПоляФормы.ПолеВвода Или ТекущийПоток.Вид = ВидПоляФормы.ПолеФлажка)
	Тогда
		ВызватьИсключение СтрШаблон("%1 %2: установка свойства ""%1"" доступно только для поля ввода формы",
			ИмяСвойства, ИмяТекущегоЭлемента());
	КонецЕсли;

	Свойство(ИмяСвойства, ФорматРедактирования);
	
	Возврат ЭтотОбъект;

КонецФункции

