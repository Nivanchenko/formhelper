// Устанавливает массив параметров выбора элемента формы
//
// Параметры:
//    ПараметрыВыбора - ФиксированныйМассив Из ПараметрыВыбора - параметры выбора
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция ПараметрыВыбора(ПараметрыВыбора) Экспорт 

	ИмяСвойства = "ПараметрыВыбора";
	ИмяТипа = "ФиксированныйМассив";

	ПроверитьТипВходящегоПараметра(ПараметрыВыбора, ИмяСвойства, ИмяТипа);

	ВсеЭлементыИмеютКорректныйТип = Истина;
	Для каждого ЭлементМассива Из ПараметрыВыбора Цикл
		Если Не ТипЗнч(ЭлементМассива) = Тип("ПараметрыВыбора") Тогда
			ВсеЭлементыИмеютКорректныйТип = Ложь;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если Не ВсеЭлементыИмеютКорректныйТип Тогда
		ВызватьИсключение СтрШаблон("%1: один или несколько элементов массива %1 имеют некорректный тип", ИмяСвойства);
	КонецЕсли;

	Свойство(ИмяСвойства, ПараметрыВыбора);
	
	Возврат ЭтотОбъект;

КонецФункции

