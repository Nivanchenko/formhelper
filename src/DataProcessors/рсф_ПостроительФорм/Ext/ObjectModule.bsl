КонецФункции // Переместить()

// Добавляет обработчик события для элемента
//
// Параметры:
//    Имя   - Строка - наименование события
//    Метод - Строка - имя вызываемого метода обработчика события
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция Обработчик(Имя, Метод) Экспорт 

	ПроверитьТекущийЭлемент();
	// TODO: Контролировать наименования обработчиков в зависимости от типа элемента
	//       и корректность наименования метода

	ТекущийЭлемент.Обработчики.Вставить(Имя, Метод);
	
	Возврат ЭтотОбъект;

КонецФункции // ДобавитьОбработчик()

// Устанавливает признак вывода заголовка для элемента формы
//
// Параметры:
//    ОтображатьЗаголовок - Булево - признак необходимости вывода заголовка элемента
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция ОтображатьЗаголовок(ОтображатьЗаголовок) Экспорт 

	ИмяСвойства = "ОтображатьЗаголовок";
	ИмяТипа = "Булево";

	ПроверитьТипВходящегоПараметра(ОтображатьЗаголовок, ИмяСвойства, ИмяТипа);
	
	Свойство(ИмяСвойства, ОтображатьЗаголовок);
	
	Возврат ЭтотОбъект;

КонецФункции

// Устанавливает признак отображения данных поля ввода в режиме пароля
//
// Параметры:
//    РежимПароля - Булево, Неопределено - признак отображения данных поля ввода в режиме пароля
//
// Возвращаемое значение:
//    ОбработкаОбъект.ПостроительФорм - эта обработка для дальнейшего вызова функций в "текучем" стиле
//
Функция РежимПароля(РежимПароля) Экспорт 

	ИмяСвойства = "РежимПароля";

	МассивИменТипа = Новый Массив;
	МассивИменТипа.Добавить("Булево");
	МассивИменТипа.Добавить("Неопределено");
	
	ПроверитьТипВходящегоПараметра(РежимПароля, ИмяСвойства, МассивИменТипа);
	ПроверитьСвойствоДоступноТолькоДляПоляВвода(ИмяСвойства);

	Свойство(ИмяСвойства, РежимПароля);
	
	Возврат ЭтотОбъект;

КонецФункции

